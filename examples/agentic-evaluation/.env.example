# Copy this file to .env and fill in your values:
#   cp .env.example .env

# LLM provider API key — required for LLM-based scorers
# Set the key for whichever provider you use in the notebooks
OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# Limits parallel evaluation workers to 1 (prevents threading issues with some scorers)
MLFLOW_GENAI_EVAL_MAX_WORKERS=1
